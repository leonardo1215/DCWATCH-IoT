        "func": "let d = msg.payload;\n\nlet alertas = [];\n\nif (d.tempAmb > 30)\n    alertas.push(`🌡 Temperatura Ambiente Alta: ${d.tempAmb}°C`);\n\nif (d.tempRack > 35)\n    alertas.push(`🔥 Temperatura Rack Alta: ${d.tempRack}°C`);\n\nif (d.smoke > 60)\n    alertas.push(`💨 Fumaça Detectada: ${d.smoke}%`);\n\nif (d.motion)\n    alertas.push(`🚶 Movimento Detectado`);\n\nif (d.doorOpen)\n    alertas.push(`🚪 Porta Aberta`);\n\nif (d.energyFail)\n    alertas.push(`⚡ Falha de Energia`);\n\nif (alertas.length === 0)\n    return null;\n\nmsg.payload = {\n    chatId: 5383801368,\n    type: \"message\",\n    content:\n`🚨 ALERTA DC WATCH\n\nRack: rack01\n\n${alertas.join('\\n')}\n\n🕒 ${new Date().toLocaleString('pt-BR')}`\n};\n\nreturn msg;",
