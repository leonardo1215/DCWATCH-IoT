    {
        "id": "3e84f6656537bb5a",
        "type": "ui-template",
        "z": "8a25a0acf9016a45",
        "group": "a277c203cbbc8071",
        "page": "",
        "ui": "",
        "name": "CSS DC Watch",
        "order": 1,
        "width": 0,
        "height": 0,
        "head": "",
        "format": "<style>\nbody, .v-application {\n  background: #050505 !important;\n  color: #F8FAFC !important;\n}\n.v-toolbar, .nrdb-header {\n  background: #050505 !important;\n  border-bottom: 1px solid #2A2A2A !important;\n}\n.nrdb-ui-group {\n  background: linear-gradient(145deg, #111111, #080808) !important;\n  border: 1px solid #2A2A2A !important;\n  border-radius: 16px !important;\n  box-shadow: 0 0 18px rgba(239, 68, 68, 0.10) !important;\n}\n.nrdb-ui-group-title {\n  color: #F8FAFC !important;\n  font-weight: 700 !important;\n}\n.nrdb-ui-widget { color: #F8FAFC !important; }\n.nrdb-ui-text {\n  background: rgba(17, 17, 17, 0.95) !important;\n  border-left: 4px solid #EF4444 !important;\n  border-radius: 12px !important;\n  padding: 10px 14px !important;\n}\n.dc-card {\n  background: linear-gradient(135deg, #111111, #080808);\n  border: 1px solid #2A2A2A;\n  border-radius: 16px;\n  padding: 18px 24px;\n  color: #F8FAFC;\n}\n.dc-accent { color: #EF4444; }\n.dc-online { color: #22C55E; font-weight: 800; }\n</style>",
        "storeOutMessages": true,
