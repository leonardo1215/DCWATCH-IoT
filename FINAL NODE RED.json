        "name": "function - Histórico",
        "func": "let d = msg.payload;\n\nif (typeof d === 'string') {\n    d = JSON.parse(d);\n}\n\n// Passa payload RAW para o histórico (nomes originais do MQTT)\nmsg.payload = {\n    status: d.status || 'NORMAL',\n    tempAmb: Number(d.tempAmb),\n    humidity: Number(d.humidity),\n    tempRack: Number(d.tempRack),\n    smoke: Number(d.smoke),\n    power: Number(d.power),\n    light: Number(d.light),\n    doorOpen: d.doorOpen || false,\n    energyFail: d.energyFail || false,\n    motion: d.motion || false,\n    fanOn: d.fanOn || false\n};\n\nreturn msg;",
