    {
        "id": "7df73c5b7058b98d",
        "type": "function",
        "z": "8a25a0acf9016a45",
        "name": "function 1 - Painel Principal",
        "func": "let d = msg.payload;\n\nif (typeof d === 'string') {\n    d = JSON.parse(d);\n}\n\nmsg.payload = {\n    status: d.status || 'NORMAL',\n    tempAmb: Number(d.tempAmb),\n    humidity: Number(d.humidity),\n    tempRack: Number(d.tempRack),\n    smoke: Number(d.smoke),\n    power: Number(d.power),\n    light: Number(d.light),\n    porta: d.doorOpen ? 'ABERTA' : 'FECHADA',\n    energia: d.energyFail ? 'FALHA' : 'OK',\n    movimento: d.motion ? 'DETECTADO' : 'NORMAL',\n    ventilacao: d.fanOn ? 'LIGADA' : 'DESLIGADA',\n    wifiRssi: d.wifiRssi || 0\n};\n\nreturn msg;",
