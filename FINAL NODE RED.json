    {
        "id": "6e0cff40226cee41",
        "type": "ui-template",
        "z": "8a25a0acf9016a45",
        "group": "a277c203cbbc8071",
        "page": "",
        "ui": "",
        "name": "Painel DC Watch",
        "order": 2,
        "width": "12",
        "height": "14",
        "head": "",
        "format": "<template>\n  <div class=\"dc-page\">\n    <div class=\"dc-hero\">\n      <div>\n        <h1><span>DC</span> Watch IoT</h1>\n        <p>Data Center Monitoring Platform • Rack 01</p>\n      </div>\n      <div class=\"online\">● MQTT ONLINE</div>\n    </div>\n\n    <div class=\"status-card\" :class=\"msg.payload.status.toLowerCase()\">\n      <div>Status Geral</div>\n      <strong>{{ msg.payload.status }}</strong>\n    </div>\n\n    <div class=\"grid\">\n      <div class=\"card\"><span>🌡️ Temp Ambiente</span><strong>{{ msg.payload.tempAmb }} °C</strong></div>\n      <div class=\"card\"><span>💧 Umidade</span><strong>{{ msg.payload.humidity }} %</strong></div>\n      <div class=\"card\"><span>🌡️ Temp Rack</span><strong>{{ msg.payload.tempRack }} °C</strong></div>\n      <div class=\"card\"><span>🔥 Fumaça</span><strong>{{ msg.payload.smoke }} %</strong></div>\n      <div class=\"card\"><span>⚡ Consumo</span><strong>{{ msg.payload.power }} %</strong></div>\n      <div class=\"card\"><span>☀️ Luminosidade</span><strong>{{ msg.payload.light }} %</strong></div>\n    </div>\n\n    <div class=\"infra\">\n      <div>🚪 Porta <strong>{{ msg.payload.porta }}</strong></div>\n      <div>⚡ Energia <strong>{{ msg.payload.energia }}</strong></div>\n      <div>👤 Movimento <strong>{{ msg.payload.movimento }}</strong></div>\n      <div>🌀 Ventilação <strong>{{ msg.payload.ventilacao }}</strong></div>\n    </div>\n  </div>\n</template>\n\n<style>\n.dc-page {\n  background:#050505;\n  color:#f8fafc;\n  font-family: Arial, sans-serif;\n  padding: 16px;\n}\n.dc-hero {\n  display:flex;\n  justify-content:space-between;\n  align-items:center;\n  background:linear-gradient(135deg,#111,#060606);\n  border:1px solid #2a2a2a;\n  border-radius:18px;\n  padding:22px;\n  margin-bottom:18px;\n}\n.dc-hero h1 { margin:0; font-size:32px; }\n.dc-hero h1 span { color:#ef4444; }\n.dc-hero p { color:#a1a1aa; margin:6px 0 0; }\n.online { color:#22c55e; font-weight:800; }\n.status-card {\n  border-radius:18px;\n  padding:22px;\n  margin-bottom:18px;\n  background:#111;\n  border-left:8px solid #22c55e;\n  display:flex;\n  justify-content:space-between;\n  align-items:center;\n  font-size:18px;\n}\n.status-card strong { font-size:28px; }\n.status-card.atencao { border-left-color:#facc15; }\n.status-card.critico { border-left-color:#ef4444; animation:pulse 1s infinite alternate; }\n.grid {\n  display:grid;\n  grid-template-columns:repeat(3,1fr);\n  gap:18px;\n  margin-bottom:18px;\n}\n.card {\n  background:linear-gradient(145deg,#111,#080808);\n  border:1px solid #2a2a2a;\n  border-radius:18px;\n  padding:24px;\n  box-shadow:0 0 18px rgba(239,68,68,.12);\n}\n.card span { color:#a1a1aa; font-size:15px; }\n.card strong { display:block; margin-top:12px; font-size:34px; }\n.infra {\n  display:grid;\n  grid-template-columns:repeat(4,1fr);\n  gap:18px;\n}\n.infra div {\n  background:#111;\n  border:1px solid #2a2a2a;\n  border-left:5px solid #ef4444;\n  border-radius:16px;\n  padding:18px;\n}\n.infra strong { display:block; margin-top:10px; font-size:20px; }\n@keyframes pulse {\n  from { box-shadow:0 0 10px rgba(239,68,68,.25); }\n  to { box-shadow:0 0 28px rgba(239,68,68,.75); }\n}\n</style>",
        "storeOutMessages": true,
        "passthru": true,
        "resendOnRefresh": true,
        "templateScope": "local",
        "className": "",
        "x": 1190,
        "y": 400,
        "wires": [
            []
        ]
    },
    {
        "id": "c596a5d179238f91",
        "type": "ui-template",
        "z": "8a25a0acf9016a45",
        "group": "",
        "page": "a96d86a1115546f7",
        "ui": "",
        "name": "Painel Histórico",
        "order": 1,
        "width": "12",
        "height": "1",
        "head": "",
        "format": "<template>\n  <div class=\"hw\">\n    <div class=\"hh\">\n      <h2>📊 Histórico DC Watch</h2>\n      <span style=\"color:#22c55e;font-size:13px;\">● {{ live }}</span>\n    </div>\n\n    <div class=\"hg\">\n      <div class=\"hc\" v-for=\"s in series\" :key=\"s.key\">\n        <div class=\"hct\">\n          <span>{{ s.icon }} {{ s.label }}</span>\n          <b :style=\"{color:s.color}\">{{ ultimo(s.key) }}{{ s.unit }}</b>\n        </div>\n        <svg viewBox=\"0 0 400 80\" style=\"width:100%;height:80px\" preserveAspectRatio=\"none\">\n          <defs>\n            <linearGradient :id=\"'g'+s.key\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n              <stop offset=\"0%\" :stop-color=\"s.color\" stop-opacity=\"0.35\"/>\n              <stop offset=\"100%\" :stop-color=\"s.color\" stop-opacity=\"0\"/>\n            </linearGradient>\n          </defs>\n          <path :d=\"area(s.key)\" :fill=\"'url(#g'+s.key+')'\"/>\n          <polyline :points=\"linha(s.key)\" :stroke=\"s.color\" stroke-width=\"2.5\" fill=\"none\"/>\n        </svg>\n      </div>\n    </div>\n\n    <div class=\"ht\">\n      <h4>📋 Últimos Registros</h4>\n      <table>\n        <thead><tr>\n          <th>Horário</th><th>Status</th><th>Temp Amb</th>\n          <th>Temp Rack</th><th>Umidade</th><th>Fumaça</th><th>Consumo</th>\n        </tr></thead>\n        <tbody>\n          <tr v-for=\"(r,i) in tabela\" :key=\"i\">\n            <td class=\"c6\">{{ r.hora }}</td>\n            <td :class=\"r.status==='NORMAL'?'ok':'er'\">{{ r.status }}</td>\n            <td>{{ r.tempAmb }}°C</td>\n            <td>{{ r.tempRack }}°C</td>\n            <td>{{ r.humidity }}%</td>\n            <td>{{ r.smoke }}%</td>\n            <td>{{ r.power }}%</td>\n          </tr>\n        </tbody>\n      </table>\n    </div>\n  </div>\n</template>\n\n<script>\nexport default {\n  data() {\n    return {\n      live: 'AGUARDANDO',\n      hist: [],\n      series: [\n        {key:'tempAmb', label:'Temp Ambiente', icon:'🌡️', color:'#ff4d4d', unit:'°C'},\n        {key:'tempRack',label:'Temp Rack',     icon:'🌡️', color:'#ff8c00', unit:'°C'},\n        {key:'humidity',label:'Umidade',        icon:'💧', color:'#00bcd4', unit:'%'},\n        {key:'power',   label:'Consumo',        icon:'⚡', color:'#4caf50', unit:'%'}\n      ]\n    }\n  },\n  computed: {\n    tabela() { return [...this.hist].reverse().slice(0,15) }\n  },\n  watch: {\n    msg: {\n      handler(m) { if(m&&m.payload) this.add(m.payload) },\n      deep: true\n    }\n  },\n  methods: {\n    add(d) {\n      this.hist.push({hora: new Date().toLocaleTimeString('pt-BR'), ...d})\n      if(this.hist.length>60) this.hist.shift()\n      this.live = 'LIVE ' + new Date().toLocaleTimeString('pt-BR')\n    },\n    vals(key) { return this.hist.map(h=>parseFloat(h[key])||0) },\n    ultimo(key) { const v=this.vals(key); return v.length?v[v.length-1]:'--' },\n    linha(key) {\n      const v=this.vals(key); if(v.length<2) return ''\n      const mn=Math.min(...v)-1, mx=Math.max(...v)+1\n      return v.map((n,i)=>((i/(v.length-1))*400)+','+(80-((n-mn)/(mx-mn))*80)).join(' ')\n    },\n    area(key) {\n      const v=this.vals(key); if(v.length<2) return ''\n      const mn=Math.min(...v)-1, mx=Math.max(...v)+1\n      const pts=v.map((n,i)=>((i/(v.length-1))*400)+','+(80-((n-mn)/(mx-mn))*80))\n      return 'M0,80 L'+pts.join(' L')+' L400,80 Z'\n    }\n  }\n}\n</script>\n\n<style>\n.hw{background:#050505;min-height:100vh;padding:24px 28px;color:#f8fafc;font-family:Arial,sans-serif;box-sizing:border-box}\n.hh{display:flex;justify-content:space-between;align-items:center;margin-bottom:24px}\n.hh h2{margin:0;font-size:22px;color:#ef4444}\n.hg{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:24px}\n.hc{background:#111;border:1px solid #2a2a2a;border-radius:14px;padding:16px}\n.hct{display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;font-size:13px;color:#a1a1aa}\n.hct b{font-size:22px}\n.ht{background:#111;border:1px solid #2a2a2a;border-radius:14px;padding:16px}\n.ht h4{margin:0 0 14px;color:#a1a1aa;font-size:14px}\ntable{width:100%;border-collapse:collapse;font-size:13px}\nth{color:#ef4444;text-align:left;padding:8px 10px;border-bottom:1px solid #2a2a2a}\ntd{padding:7px 10px;border-bottom:1px solid #1a1a1a;color:#d4d4d4}\n.c6{color:#666}.ok{color:#22c55e;font-weight:700}.er{color:#ef4444;font-weight:700}\n</style>",
